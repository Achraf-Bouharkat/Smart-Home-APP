<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <selector>
            <!-- Hover/Focused state: Glowing effect -->
            <item android:state_hovered="true">
                <layer-list>
                    <!-- Outer glow layer -->
                    <item android:bottom="-4dp" android:left="-4dp" android:right="-4dp" android:top="-4dp">
                        <shape android:shape="rectangle">
                            <corners android:radius="20dp" />
                            <solid android:color="@color/primary_glow_soft" />
                        </shape>
                    </item>
                    <!-- Inner glow layer -->
                    <item android:bottom="-2dp" android:left="-2dp" android:right="-2dp" android:top="-2dp">
                        <shape android:shape="rectangle">
                            <corners android:radius="18dp" />
                            <solid android:color="@color/primary_glow" />
                        </shape>
                    </item>
                    <!-- Main button layer -->
                    <item>
                        <shape android:shape="rectangle">
                            <corners android:radius="16dp" />
                            <solid android:color="@color/primary" />
                        </shape>
                    </item>
                </layer-list>
            </item>

            <!-- Pressed state -->
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <solid android:color="@color/primary_variant" />
                </shape>
            </item>

            <!-- Default state -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <solid android:color="@color/primary" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>